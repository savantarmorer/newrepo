# Copie para `.env` na raiz do repositório (não commitar valores reais).
# O servidor carrega automaticamente com `import 'dotenv/config'`.

# Opção simples (Resend): https://resend.com — domínio verificado ou e-mail de testes da conta
RESEND_API_KEY=
CIVIC_MAIL_FROM="Participação cívica <onboarding@resend.dev>"

# Alternativa: SMTP tradicional (preencha tudo; RESEND tem prioridade se RESEND_API_KEY estiver definida)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# CIVIC_MAIL_FROM="Participação <noreply@seudominio.com.br>"

PORT=3000
