{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "redirects": [
    {
      "source": "/teia-compliance-zero.html",
      "destination": "/master",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/candidatos",
      "destination": "/server.js"
    },
    {
      "source": "/master",
      "destination": "/teia-compliance-zero.html"
    },
    {
      "source": "/master/",
      "destination": "/teia-compliance-zero.html"
    }
  ]
}
